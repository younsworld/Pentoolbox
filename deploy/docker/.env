# Secrets injectes dans les conteneurs via docker-compose.yml (${VAR} dans
# environment:/command:). Ne JAMAIS committer ce fichier (.gitignore deja
# configure) - permissions hote attendues: chmod 600.
#
# OPENVAS_PASSWORD et PASSWORD DOIVENT rester identiques: OPENVAS_PASSWORD
# est ce que lit le conteneur pentoolbox pour s'authentifier en GMP,
# PASSWORD est le nom de variable que l'image immauss/openvas elle-meme
# attend pour fixer ce meme mot de passe admin. Pas de mecanisme natif dans
# un fichier .env pour les garder synchronises automatiquement: changez les
# deux a la fois.
OPENVAS_PASSWORD=admin
PASSWORD=admin

MSF_RPC_PASSWORD=msfpass
